# ── Runtime ──
APP_ENV=testbed
TARGET_PROVIDER=auto
TARGET_MODEL=
TARGET_API_KEY=
TARGET_ALLOW_LOCAL_URLS=true
TARGET_CONTRACT_TIMEOUT=300

# ── Database ──
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/agentshield?ssl=require

# ── JWT ──
JWT_SECRET_KEY=<CHANGE_ME_RANDOM_32_BYTES>

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_RED_MODEL=hauhau-qwen:latest
OLLAMA_JUDGE_MODEL=qwen3.5:4b
OLLAMA_GUARD_MODEL=qwen3.5:4b
OLLAMA_BLUE_MODEL=blue-qwen35-2b-sft
OLLAMA_BASE_TARGET_MODEL=gemma4:e2b
OLLAMA_RED_TARGET_MODEL=hauhau-qwen:latest
OLLAMA_JUDGE_TARGET_MODEL=qwen3.5:4b
OLLAMA_BLUE_TARGET_MODEL=blue-qwen35-2b-sft
OLLAMA_GENERATION_API=generate
OLLAMA_RED_PROMPT_FORMAT=chatml
OLLAMA_KEEP_ALIVE=30s
OLLAMA_BASE_NUM_CTX=4096
OLLAMA_RED_NUM_CTX=4096
OLLAMA_BLUE_NUM_CTX=4096
OLLAMA_JUDGE_NUM_CTX=4096
OLLAMA_GUARD_NUM_CTX=4096

# ── LLM Request ──
LLM_REQUEST_TIMEOUT=300
LLM_REQUEST_RETRIES=4
LLM_RETRY_BACKOFF_BASE=2.0
LLM_CHAT_FALLBACK_ON_EOF=true
LLM_DEFAULT_NUM_PREDICT=2048
RED_AGENT_NUM_PREDICT=4096

# ── Red Adaptive Campaign ──
# Offline-safe campaign script only. This overrides Red Agent model for campaign runs.
RED_CAMPAIGN_MODEL=hauhau-qwen:latest
RED_CAMPAIGN_NUM_PREDICT=8192
RED_CAMPAIGN_GENERATION_ATTEMPTS=3

# 공격 프롬프트 최소 길이 (category별 개별 설정 권장)
# CLI --min-attack-chars > category별 env > 전역 env > 코드 기본값 순 적용
#RED_CAMPAIGN_MIN_ATTACK_CHARS=        # 전역 오버라이드 (category별이 없을 때 사용)
RED_CAMPAIGN_MIN_ATTACK_CHARS_LLM01=1500
RED_CAMPAIGN_MIN_ATTACK_CHARS_LLM02=1800
RED_CAMPAIGN_MIN_ATTACK_CHARS_LLM06=1200
RED_CAMPAIGN_MIN_ATTACK_CHARS_LLM07=2000
RED_CAMPAIGN_MAX_ATTACK_CHARS=5000

# 실서비스 URL: --target-url CLI 또는 이 env로 지정 (required)
#RED_CAMPAIGN_TARGET_URL=https://your-chatbot.example.com/chat
RED_CAMPAIGN_OUTPUT_DIR=data/red_campaigns
RED_CAMPAIGN_SEEDS=5
RED_CAMPAIGN_ROUNDS=5

# 학습 후보 최소 strength (4=tool_call/execution, 5=sensitive_leak/privileged_tool)
RED_CAMPAIGN_MIN_SUCCESS_STRENGTH=4
RED_CAMPAIGN_CONTINUE_AFTER_SUCCESS=false
DEMO_RED_CONTINUE_AFTER_SUCCESS=false

# Multi-turn conversation (기본 single — 실서비스에서는 single 유지)
RED_CAMPAIGN_CONVERSATION_MODE=single
RED_CAMPAIGN_MAX_HISTORY_TURNS=6

# Tool execution 로그 검증 (testbed 한정, 실서비스 자동 skip)
RED_CAMPAIGN_VERIFY_TOOL_EXECUTION=false

# ── ChromaDB ──
CHROMADB_MODE=persistent
CHROMADB_PERSIST_PATH=./chromadb_data
CHROMADB_HOST=localhost
CHROMADB_PORT=8003
RED_RAG_REFERENCE_LIMIT=8
RED_RAG_RECENT_REFERENCE_LIMIT=4


# ── Pipeline ──
PHASE1_ALLOW_FILE_FALLBACK=true
ATTACK_PATTERN_PATH=data/curated_attack_sets/testbed_manual_mixed_10.json
PHASE1_TIMEOUT=120
PHASE2_TIMEOUT=300
PHASE2_MAX_ROUNDS=5
PHASE2_PROBE_TIMEOUT=60
FRR_TARGET_TIMEOUT=180
PHASE4_MAX_ITERATIONS=3

# ── Monitoring ──
MONITORING_PROXY_URL=http://localhost:8002

# ── LoRA Adapters ──
LORA_RED_PATH=./adapters/lora-red
LORA_JUDGE_PATH=./adapters/lora-judge
LORA_BLUE_PATH=./adapters/LoRA_blue

# ── Testbed ──
TESTBED_DB_URL=postgresql://testbed:testbed@localhost:5432/testbed
TOOL_GATEWAY_URL=http://localhost:8020
TESTBED_TOOL_GATEWAY_DOCKER_URL=http://tool_gateway:8020
TOOL_GATEWAY_PORT=8020
TESTBED_PORT=8010
TESTBED_SECURITY_MODE=weak
TESTBED_OLLAMA_TIMEOUT=180
TESTBED_OLLAMA_MAX_RETRIES=5
TESTBED_OLLAMA_TEMPERATURE=0.2
TESTBED_OLLAMA_NUM_CTX=4096
TESTBED_MAX_TOOL_LOOPS=3
TESTBED_TOOL_GATEWAY_TIMEOUT=180
ALLOW_STUB_TOOLS=false
