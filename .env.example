# ── 데이터베이스 ──
# 로컬 PostgreSQL (Docker 없이): 아래 그대로 또는 본인 USER/PW/PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://agentshield:agentshield@localhost:5432/agentshield
# Docker Compose의 db만 쓰고 백엔드는 호스트에서 실행할 때도 보통 localhost:5432 (포트 매핑)
# DATABASE_URL=postgresql+asyncpg://agentshield:agentshield@127.0.0.1:5432/agentshield

# ── JWT (반드시 변경) ──
JWT_SECRET_KEY=change-me-in-production

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_RED_MODEL=gemma4:26b
OLLAMA_JUDGE_MODEL=agent-judge
OLLAMA_GUARD_MODEL=qwen3.5:4b
OLLAMA_BLUE_MODEL=agent-blue
LLM_REQUEST_TIMEOUT=300
LLM_DEFAULT_NUM_PREDICT=2048
RED_AGENT_NUM_PREDICT=4096

# ── ChromaDB ──
CHROMADB_PERSIST_PATH=./chromadb_data

# ── Pipeline ──
PHASE1_TIMEOUT=120
PHASE2_TIMEOUT=300
PHASE2_MAX_ROUNDS=10

# ── Proxy ──
DEFENSE_PROXY_URL=http://localhost:8001
MONITORING_PROXY_URL=http://localhost:8002

# ── LoRA Adapters ──
LORA_RED_PATH=./adapters/lora-red
LORA_JUDGE_PATH=./adapters/lora-judge
LORA_BLUE_PATH=./adapters/lora-blue
