# ── Runtime ──
APP_ENV=testbed
TARGET_PROVIDER=auto
TARGET_MODEL=
TARGET_API_KEY=
TARGET_ALLOW_LOCAL_URLS=true
TARGET_CONTRACT_TIMEOUT=300

# ── Database ──
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/agentshield?ssl=require

# ── JWT ──
JWT_SECRET_KEY=<CHANGE_ME_RANDOM_32_BYTES>

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_RED_MODEL=gemma4-ara-abliterated
OLLAMA_JUDGE_MODEL=qwen3.5:4b
OLLAMA_GUARD_MODEL=qwen3.5:4b
OLLAMA_BLUE_MODEL=agent-blue
OLLAMA_BASE_TARGET_MODEL=gemma4:e2b
OLLAMA_RED_TARGET_MODEL=qwen3.5:4b
OLLAMA_JUDGE_TARGET_MODEL=qwen3.5:4b
OLLAMA_BLUE_TARGET_MODEL=qwen3.5:4b
OLLAMA_GENERATION_API=generate
OLLAMA_KEEP_ALIVE=30s
OLLAMA_BASE_NUM_CTX=4096
OLLAMA_RED_NUM_CTX=4096
OLLAMA_BLUE_NUM_CTX=4096
OLLAMA_JUDGE_NUM_CTX=4096
OLLAMA_GUARD_NUM_CTX=4096

# ── LLM Request ──
LLM_REQUEST_TIMEOUT=300
LLM_REQUEST_RETRIES=4
LLM_RETRY_BACKOFF_BASE=2.0
LLM_CHAT_FALLBACK_ON_EOF=true
LLM_DEFAULT_NUM_PREDICT=2048
RED_AGENT_NUM_PREDICT=4096

# ── ChromaDB ──
CHROMADB_MODE=persistent
CHROMADB_PERSIST_PATH=./chromadb_data
CHROMADB_HOST=localhost
CHROMADB_PORT=8003
RED_RAG_REFERENCE_LIMIT=8
RED_RAG_RECENT_REFERENCE_LIMIT=4


# ── Pipeline ──
PHASE1_ALLOW_FILE_FALLBACK=true
ATTACK_PATTERN_PATH=data/curated_attack_sets/testbed_manual_mixed_10.json
PHASE1_TIMEOUT=120
PHASE2_TIMEOUT=300
PHASE2_MAX_ROUNDS=5
PHASE2_PROBE_TIMEOUT=60
FRR_TARGET_TIMEOUT=180
PHASE4_MAX_ITERATIONS=3

# ── Monitoring ──
MONITORING_PROXY_URL=http://localhost:8002

# ── LoRA Adapters ──
LORA_RED_PATH=./adapters/lora-red
LORA_JUDGE_PATH=./adapters/lora-judge
LORA_BLUE_PATH=./adapters/lora-blue

# ── Testbed ──
TESTBED_DB_URL=postgresql://testbed:testbed@localhost:5432/testbed
TOOL_GATEWAY_URL=http://localhost:8020
TESTBED_TOOL_GATEWAY_DOCKER_URL=http://tool_gateway:8020
TOOL_GATEWAY_PORT=8020
TESTBED_PORT=8010
TESTBED_SECURITY_MODE=weak
TESTBED_OLLAMA_TIMEOUT=180
TESTBED_OLLAMA_MAX_RETRIES=5
TESTBED_OLLAMA_TEMPERATURE=0.2
TESTBED_OLLAMA_NUM_CTX=4096
TESTBED_MAX_TOOL_LOOPS=3
TESTBED_TOOL_GATEWAY_TIMEOUT=180
ALLOW_STUB_TOOLS=false
